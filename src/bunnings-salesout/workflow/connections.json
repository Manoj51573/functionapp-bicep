{
  "serviceProviderConnections": {
    "FileSystem": {
        "displayName": "fileShareSapBw",
        "parameterValues": {
            "mountPath": "@appsetting('FileSystem_mountPath')"
        },
        "serviceProvider": {
            "id": "/serviceProviders/FileSystem"
        }
    },
    "azureTables": {
      "displayName": "ReferenceStoreConnection",
      "parameterValues": {
        "connectionString": "@appsetting('AzureTableConnectionString')"
      },
      "serviceProvider": {
        "id": "/serviceProviders/azureTables"
      }
    },
    "sql": {
      "displayName": "sql-connection-controldatabase",
      "parameterSetName": "ManagedServiceIdentity",
      "parameterValues": {
        "authProvider": {
          "Type": "ManagedServiceIdentity"
        },
        "databaseName": "@appsetting('SqlDatabaseName')",
        "serverName": "@appsetting('SqlServerName')",
        "managedIdentityType": "SystemAssigned"
      },
      "serviceProvider": {
        "id": "/serviceProviders/sql"
      }
    },
    "sftp": {
      "displayName": "sftp-connection-si",
      "parameterValues": {
        "sshHostAddress": "@appsetting('SFTP_HOSTNAME_SI_SERVER')",
        "userName": "@appsetting('SFTP_USERNAME_SI_SERVER')",
        "password": "@appsetting('SFTP_USERPWD_SI_SERVER')",
        "rootFolder": "@appsetting('SFTP_ROOTFOLDER_SI_SERVER')"
      },
      "serviceProvider": {
        "id": "/serviceProviders/sftp"
      }
    },
    "adls": {
      "displayName": "adls-connection",
      "parameterSetName": "ManagedServiceIdentity",
      "parameterValues": {
        "storageAccountName": "dgitnpeaseadls",
       "blobStorageEndpoint": "https://@{appsetting('Dulux_ADLS_AccountName')}.blob.core.windows.net",
        "authProvider": {
          "type": "ManagedServiceIdentity"
        },
        "managedIdentityType": "SystemAssigned"
      },
      "serviceProvider": {
        "id": "/serviceProviders/AzureBlob"
      }
    },
    "AzureBlob": {
            "displayName": "azureblob",
            "parameterSetName": "ManagedServiceIdentity",
            "parameterValues": {
                "authProvider": {
                    "Type": "ManagedServiceIdentity"
                },
                "blobStorageEndpoint": "https://@{appsetting('DataStorage_AccountName')}.blob.core.windows.net"
            },
            "serviceProvider": {
                "id": "/serviceProviders/AzureBlob"
            }
        }
  },
